# Telegram Bot API token from @BotFather
NUXT_BOT_TOKEN=

# Bot username without @
NUXT_TELEGRAM_BOT_NAME=arsTeleShopBot

# Telegram Chat ID of the manager (receives new orders)
NUXT_MANAGER_CHAT_ID=

# Public URL of the Web App (HTTPS) — for "Открыть магазин" button on /start
NUXT_APP_URL=https://tele-shop-sigma.vercel.app/

# Optional: maps / geocoding (if used in checkout)
YANDEX_MAPS_API_KEY=
YANDEX_GEOCODER_API_KEY=

# Optional: address suggestions (if used)
DADATA_TOKEN=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# IMPORTANT: server-only secret (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

