# Telegram Bot API token from @BotFather
NUXT_BOT_TOKEN=

# Bot username without @
NUXT_TELEGRAM_BOT_NAME=arsTeleShopBot
NUXT_MAX_BOT_URL=https://max.ru/id032384437278_bot
NUXT_MAX_API_BASE_URL=https://platform-api.max.ru/
NUXT_MAX_API_TOKEN=f9LHodD0cOKBCnRdm5Im6otKqO-defMAmuANhXwoDRCJX6JeUjVnsgev38ufRKqHPcx85WwGw-c7OyIRhnf_
# Токен бота MAX для проверки initData мини-приложения (если пусто — используется NUXT_MAX_API_TOKEN). White-label: см. shops.integration_keys.max_bot_token
NUXT_MAX_MINIAPP_BOT_TOKEN=
# Секрет для проверки заголовка X-Max-Bot-Api-Secret на POST /api/webhook-max (как в подписке MAX)
NUXT_MAX_WEBHOOK_SECRET=
# Telegram Chat ID of the manager (receives new orders)
NUXT_MANAGER_CHAT_ID=

# Public URL of the Web App (HTTPS) — for "Открыть магазин" button on /start
NUXT_APP_URL=https://tele-shop-sigma.vercel.app/

# Legacy fallback: pickup points JSON (used only if restaurants API has no data)
# Example:
# NUXT_PICKUP_POINTS_JSON=[{"id":"center","name":"Ресторан Центр","address":"Улан-Удэ, ул. Ленина, 10"}]
NUXT_PICKUP_POINTS_JSON=

# Legacy fallback: available fulfillment methods
NUXT_FULFILLMENT_TYPES=delivery,pickup

# Optional: maps / geocoding (if used in checkout)
YANDEX_MAPS_API_KEY=
YANDEX_GEOCODER_API_KEY=

# Optional: address suggestions (if used)
DADATA_TOKEN=

# Supabase
SUPABASE_URL=
SUPABASE_KEY=

# IMPORTANT: server-only secret (never expose to client)
SUPABASE_SERVICE_ROLE_KEY=

# Multi-tenant bootstrap (recommended in SaaS mode)
# Configure these values per shop in table `shops`.
# Fallback bot token and manager chat are used only when shop values are absent.

